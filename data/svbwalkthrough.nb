Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "MatchAnsatz", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MatchAnsatz", "[", 
    RowBox[{"exp_", ",", "ansatz_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"svlistall", ",", "sys", ",", "sys1", ",", "len", ",", "sol"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"svlistall", "=", 
       RowBox[{
        RowBox[{"Cases", "[", 
         RowBox[{"ansatz", ",", "_I", ",", "Infinity"}], "]"}], "//", 
        "DeleteDuplicates"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"len", "=", 
       RowBox[{"Length", "[", "ansatz", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"sys", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"CoefficientArrays", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{"(", "exp", ")"}]}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"c", "/@", 
               RowBox[{"Range", "[", "len", "]"}]}], ")"}], ".", "ansatz"}]}],
            ",", "svlistall"}], "]"}], "[", 
         RowBox[{"[", "2", "]"}], "]"}], "//", "Normal"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"sys1", "=", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"sys", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "/.", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Pi", "->", "pi"}], ",", 
                RowBox[{
                 RowBox[{"f", "[", 
                  RowBox[{"3", ",", "3"}], "]"}], "->", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"f", "[", "3", "]"}], "^", "2"}], "/", "2"}]}]}], 
               "}"}]}], "//", 
             RowBox[{
              RowBox[{"MonomialList", "[", 
               RowBox[{"#", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"f", "[", "3", "]"}], ",", "pi", ",", 
                  RowBox[{"f", "[", "5", "]"}], ",", 
                  RowBox[{"f", "[", "7", "]"}], ",", 
                  RowBox[{"f", "[", 
                   RowBox[{"5", ",", "3"}], "]"}]}], "}"}]}], "]"}], "&"}]}], 
            ")"}], "/.", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"pi", "->", "1"}], ",", 
             RowBox[{
              RowBox[{"f", "[", "3", "]"}], "->", "1"}], ",", 
             RowBox[{
              RowBox[{"f", "[", "5", "]"}], "->", "1"}], ",", 
             RowBox[{
              RowBox[{"f", "[", "7", "]"}], "->", "1"}]}], "}"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "[", "sys", "]"}]}], "}"}]}], "]"}], "//", 
        "Flatten"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"sol", "=", 
       RowBox[{
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{"Thread", "@", 
           RowBox[{"Equal", "[", 
            RowBox[{"sys1", ",", "0"}], "]"}]}], ",", 
          RowBox[{"c", "/@", 
           RowBox[{"Range", "[", "len", "]"}]}]}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{
        RowBox[{"c", "/@", 
         RowBox[{"Range", "[", "len", "]"}]}], "/.", "sol"}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.987497163877234*^9, 3.987497333607349*^9}, {
  3.987497381967176*^9, 3.9874974233782177`*^9}, {3.98749749262165*^9, 
  3.9874975269049187`*^9}},
 CellLabel->
  "In[592]:=",ExpressionUUID->"d199d9eb-e870-4cd0-a220-0b7f74c6eba3"],

