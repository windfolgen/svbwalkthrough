Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "ResolveCondition", "]"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "this", " ", "is", " ", "used", " ", "to", " ", "deal", " ", "with", " ", 
    "quadratic", " ", "polynomials", " ", "in", " ", "the", " ", 
    "intermediate", " ", "steps"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "ResolveCondition", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{"\"\<num\>\"", "->", "1"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ResolveCondition", "[", 
    RowBox[{"list_", ",", "var_", ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "pow", ",", "vlist", ",", "nvlist", ",", "R", ",", "rep", ",", "pos", 
       ",", "result", ",", "dis", ",", "a", ",", "tem", ",", "tag", ",", 
       "replam", ",", "sys", ",", "sol", ",", "exp"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"result", "=", "list"}], ";", "\[IndentingNewLine]", 
      RowBox[{"vlist", "=", 
       RowBox[{
        RowBox[{"Cases", "[", 
         RowBox[{"list", ",", 
          RowBox[{
           RowBox[{"HoldPattern", "[", 
            RowBox[{"V2", "[", 
             RowBox[{"x", "[", 
              RowBox[{"_", ",", "var"}], "]"}], "]"}], "]"}], "|", 
           RowBox[{"HoldPattern", "[", 
            RowBox[{"V2", "[", 
             RowBox[{"x", "[", 
              RowBox[{"var", ",", "_"}], "]"}], "]"}], "]"}]}], ",", 
          "Infinity"}], "]"}], "//", "DeleteDuplicates"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nvlist", "=", 
       RowBox[{
        RowBox[{"Cases", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"OptionValue", "[", "\"\<num\>\"", "]"}], "}"}], ",", 
          RowBox[{
           RowBox[{"HoldPattern", "[", 
            RowBox[{"V2", "[", 
             RowBox[{"x", "[", 
              RowBox[{"_", ",", "var"}], "]"}], "]"}], "]"}], "|", 
           RowBox[{"HoldPattern", "[", 
            RowBox[{"V2", "[", 
             RowBox[{"x", "[", 
              RowBox[{"var", ",", "_"}], "]"}], "]"}], "]"}]}], ",", 
          "Infinity"}], "]"}], "//", "DeleteDuplicates"}]}], ";", 
      RowBox[{"(*", 
       RowBox[{"variables", " ", "in", " ", "the", " ", "numerator"}], "*)"}],
       "\[IndentingNewLine]", 
      RowBox[{"rep", "=", 
       RowBox[{"Thread", "@", 
        RowBox[{"Rule", "[", 
         RowBox[{"vlist", ",", 
          RowBox[{"R", "*", "vlist"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pow", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Exponent", "[", 
          RowBox[{"#", ",", "R"}], "]"}], "&"}], "/@", 
        RowBox[{"(", 
         RowBox[{"list", "/.", "rep"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Max", "[", "pow", "]"}], "<", "2"}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"{", 
          RowBox[{"result", ",", 
           RowBox[{"{", "}"}], ",", 
           RowBox[{"{", "}"}], ",", "1"}], "}"}], "]"}]}], "]"}], ";", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"all", " ", "linear", " ", "polynomial"}], ",", " ", 
        RowBox[{"no", " ", "need", " ", "to", " ", "resolve"}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Count", "[", 
          RowBox[{"pow", ",", "2"}], "]"}], "==", "1"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "only", " ", "one", " ", "quadratic", " ", "polynomials", " ", 
          "present"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"pos", "=", 
          RowBox[{
           RowBox[{"Position", "[", 
            RowBox[{"pow", ",", "2"}], "]"}], "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "this", " ", "quadratic", " ", "polynomial", " ", "may", " ", 
           "need", " ", "simplificatopn"}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"sys", "=", 
          RowBox[{"Thread", "@", 
           RowBox[{"Equal", "[", 
            RowBox[{
             RowBox[{"Delete", "[", 
              RowBox[{"list", ",", "pos"}], "]"}], ",", "0"}], "]"}]}]}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"sol", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"Solve", "[", 
             RowBox[{"sys", ",", "vlist"}], "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}], "//", "Quiet"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"exp", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"list", "[", 
             RowBox[{"[", "pos", "]"}], "]"}], "/.", "sol"}], "//", 
