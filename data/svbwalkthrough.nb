               RowBox[{
                RowBox[{"FreeQ", "[", 
                 RowBox[{"#", ",", "v"}], "]"}], "&"}], "/@", "list"}], ",", 
              "False"}], "]"}], "=!=", "4"}]}], ",", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<four conditions needed for cut of the loop: \>\"", ",", 
             RowBox[{"x", "[", "v", "]"}]}], "]"}], ";", 
           RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"vlist", "=", 
         RowBox[{
          RowBox[{"Cases", "[", 
           RowBox[{"list", ",", 
            RowBox[{"V2", "[", 
             RowBox[{"a_", "/;", 
              RowBox[{"(", 
               RowBox[{"!", 
                RowBox[{"FreeQ", "[", 
                 RowBox[{
                  RowBox[{"{", "a", "}"}], ",", "v"}], "]"}]}], ")"}]}], 
             "]"}], ",", "Infinity"}], "]"}], "//", "DeleteDuplicates"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"OptionValue", "[", "\"\<outputlevel\>\"", "]"}], ">", 
           "1"}], ",", 
          RowBox[{"Print", "[", 
           RowBox[{"\"\<        The four conditions are: \>\"", ",", 
            RowBox[{"list", "//", "ShowV2"}]}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"rep", "=", 
         RowBox[{"Thread", "@", 
          RowBox[{"Rule", "[", 
           RowBox[{"vlist", ",", 
            RowBox[{"R", "*", "vlist"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"pow", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Exponent", "[", 
            RowBox[{"#", ",", "R"}], "]"}], "&"}], "/@", 
          RowBox[{"(", 
           RowBox[{"list", "/.", "rep"}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"AnyTrue", "[", 
           RowBox[{"pow", ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"#", "=!=", "1"}], ")"}], "&"}]}], "]"}], ",", 
          RowBox[{"Print", "[", 
           RowBox[{
           "\"\<        the Jacbian need to be calculated by hand: \>\"", ",",
             "list"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"rep", "=", 
         RowBox[{"Thread", "@", 
          RowBox[{"Rule", "[", 
           RowBox[{"vlist", ",", 
            RowBox[{
             RowBox[{"vlist", "/.", 
              RowBox[{"{", 
               RowBox[{"x", "->", "y"}], "}"}]}], "/.", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"V2", "[", 
                 RowBox[{"y", "[", 
                  RowBox[{"a_", ",", "v"}], "]"}], "]"}], ":>", 
                RowBox[{
                 RowBox[{"-", "2"}], 
                 RowBox[{"V", "[", 
                  RowBox[{"x", "[", 
                   RowBox[{"a", ",", "v"}], "]"}], "]"}]}]}], ",", 
               RowBox[{
                RowBox[{"V2", "[", 
                 RowBox[{"y", "[", 
                  RowBox[{"v", ",", "a_"}], "]"}], "]"}], ":>", 
                RowBox[{"2", 
                 RowBox[{"V", "[", 
                  RowBox[{"x", "[", 
                   RowBox[{"v", ",", "a"}], "]"}], "]"}]}]}]}], "}"}]}]}], 
           "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<rep: \>\"", ",", "rep"}], "]"}], ";"}], 
         RowBox[{"(*", 
          RowBox[{"take", " ", "the", " ", "derivative"}], "*)"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"tem", "=", 
         RowBox[{"list", "/.", "rep"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<tem: \>\"", ",", "tem"}], "]"}], ";"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"implement", " ", "the", " ", "cut", " ", "condition"}], 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{"sol", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Solve", "[", 
            RowBox[{
             RowBox[{"Thread", "@", 
              RowBox[{"Equal", "[", 
               RowBox[{"list", ",", "0"}], "]"}]}], ",", "vlist"}], "]"}], 
           "[", 
           RowBox[{"[", "1", "]"}], "]"}], "//", "Quiet"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<sol: \>\"", ",", "sol"}], "]"}], ";"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"jac", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"tem", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", 
               RowBox[{"tem", "[", 
                RowBox[{"[", "j", "]"}], "]"}]}], "//", "Expand"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", 
               RowBox[{"Length", "[", "tem", "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", 
               RowBox[{"Length", "[", "tem", "]"}]}], "}"}]}], "]"}], "/.", 
           "sol"}], "//", "Expand"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"sim", "=", 
         RowBox[{
          RowBox[{"Det", "[", 
           RowBox[{"jac", "-", 
            RowBox[{"DiagonalMatrix", "[", 
             RowBox[{"Diagonal", "[", "jac", "]"}], "]"}]}], "]"}], "//", 
          "Factor"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"OptionValue", "[", "\"\<outputlevel\>\"", "]"}], ">", 
           "1"}], ",", 
          RowBox[{"Print", "[", 
           RowBox[{
           "\"\<        The corresponding Jacobian matrix is: \>\"", ",", 
            RowBox[{"MatrixForm", "[", 
             RowBox[{
              RowBox[{"jac", "//", "Factor"}], "//", "ShowV2"}], "]"}]}], 
           "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"tag", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Cases", "[", 
                 RowBox[{"#", ",", 
                  RowBox[{
                   RowBox[{"HoldPattern", "[", 
                    RowBox[{
                    RowBox[{"x", "[", 
                    RowBox[{"a_", ",", "v"}], "]"}], "|", 
                    RowBox[{"x", "[", 
                    RowBox[{"v", ",", "a_"}], "]"}]}], "]"}], "->", "a"}], 
                  ",", "Infinity"}], "]"}], "//", "DeleteDuplicates"}], ")"}],
               "&"}], "/@", "list"}], ")"}], "/.", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", "a_", "}"}], ":>", "a"}], "}"}]}], "//", 
          "DeleteDuplicates"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"result", "=", 
         RowBox[{"PerfectSquareOut", "[", 
          RowBox[{
           RowBox[{"Det", "[", "jac", "]"}], "//", "Factor"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"FreeQ", "[", 
           RowBox[{
            RowBox[{"result", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", "V2"}], "]"}], ",", 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Subscript", "[", 
              RowBox[{"\[Lambda]", ",", "tag"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"result", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", 
               RowBox[{"Plus", "@@", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"sim", "/", 
                    RowBox[{
                    RowBox[{"result", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "^", "2"}]}], "//", 
                    "Factor"}], ")"}], ",", 
                  RowBox[{"-", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"sim", "-", 
                    RowBox[{"Det", "[", "jac", "]"}]}], ")"}], "/", 
                    RowBox[{
                    RowBox[{"result", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "^", "2"}]}], "//", 
                    "Factor"}], ")"}]}]}], "}"}]}]}], "}"}]}], "}"}], "]"}], 
          ",", 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Subscript", "[", 
              RowBox[{"\[Lambda]", ",", "tag"}], "]"}], ",", "result"}], 
            "}"}], "]"}]}], "]"}], ";"}]}], "\[IndentingNewLine]", "]"}]}], 
    ";"}]}]}]], "Input",
