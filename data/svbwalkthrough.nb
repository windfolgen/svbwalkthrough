Cell[CellGroupData[{

Cell["\<\
series expansion for 1/(z-zz)/(1-v)(a little tedious, more proper for your \
agent)\
\>", "Subsection",
 CellChangeTimes->{{3.986281424784267*^9, 3.9862814299299583`*^9}, {
  3.9862850127113657`*^9, 3.986285026380365*^9}, {3.987584836582603*^9, 
  3.987584837686593*^9}, {3.9875849786219482`*^9, 
  3.9875849858177547`*^9}},ExpressionUUID->"3b08c5f2-7dd6-4eb8-9138-\
a008502806d6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"1", "/", "u"}], "==", 
      RowBox[{"z", "*", "zz"}]}], ",", 
     RowBox[{
      RowBox[{"v", "/", "u"}], "==", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "z"}], ")"}], "*", 
       RowBox[{"(", 
        RowBox[{"1", "-", "zz"}], ")"}]}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"z", ",", "zz"}], "}"}]}], "]"}]], "Input",
 CellFrame->{{0, 0}, {0, 2}},
 CellFrameColor->GrayLevel[0.75],
 CellChangeTimes->{{3.93984879221213*^9, 3.939848818000208*^9}},
 Background->RGBColor[0.87, 0.94, 1],
 CellLabel->
  "In[648]:=",ExpressionUUID->"b887e1ab-5c74-4a08-992b-b8e354306178"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"z", "\[Rule]", 
      FractionBox[
       RowBox[{"1", "+", "u", "-", "v", "-", 
        SqrtBox[
         RowBox[{
          RowBox[{
           RowBox[{"-", "4"}], " ", "u"}], "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "-", "u", "+", "v"}], ")"}], "2"]}]]}], 
       RowBox[{"2", " ", "u"}]]}], ",", 
     RowBox[{"zz", "\[Rule]", 
      FractionBox[
       RowBox[{"1", "+", "u", "-", "v", "+", 
        SqrtBox[
         RowBox[{
          RowBox[{
           RowBox[{"-", "4"}], " ", "u"}], "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "-", "u", "+", "v"}], ")"}], "2"]}]]}], 
       RowBox[{"2", " ", "u"}]]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"z", "\[Rule]", 
      FractionBox[
       RowBox[{"1", "+", "u", "-", "v", "+", 
        SqrtBox[
         RowBox[{
          RowBox[{
           RowBox[{"-", "4"}], " ", "u"}], "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "-", "u", "+", "v"}], ")"}], "2"]}]]}], 
       RowBox[{"2", " ", "u"}]]}], ",", 
     RowBox[{"zz", "\[Rule]", 
      FractionBox[
       RowBox[{"1", "+", "u", "-", "v", "-", 
        SqrtBox[
         RowBox[{
          RowBox[{
           RowBox[{"-", "4"}], " ", "u"}], "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "-", "u", "+", "v"}], ")"}], "2"]}]]}], 
       RowBox[{"2", " ", "u"}]]}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.939848818572382*^9},
 Background->RGBColor[0.87, 0.94, 1],
 CellLabel->
  "Out[648]=",ExpressionUUID->"9a9301bf-3daf-4a39-8a1a-b94db4bf502e"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"zrep", "=", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Power", "[", 
          RowBox[{"z", ",", "i"}], "]"}], "->", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Power", "[", 
              RowBox[{
               FractionBox[
                RowBox[{"1", "+", "u", "-", "v", "-", 
                 SqrtBox[
                  RowBox[{
                   RowBox[{
                    RowBox[{"-", "4"}], " ", "u"}], "+", 
                   SuperscriptBox[
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "-", "u", "+", "v"}], ")"}], 
                    "2"]}]]}], 
                RowBox[{"2", " ", "u"}]], ",", "i"}], "]"}], "/.", 
             RowBox[{"{", 
              RowBox[{"v", "->", 
               RowBox[{"1", "-", "Y"}]}], "}"}]}], "//", "Expand"}], "//", 
           RowBox[{
            RowBox[{"Collect", "[", 
             RowBox[{"#", ",", 
              RowBox[{"Power", "[", 
               RowBox[{"_", ",", 
                RowBox[{"1", "/", "2"}]}], "]"}], ",", "Factor"}], "]"}], 
            "&"}]}], ")"}]}], ",", 
        RowBox[{
         RowBox[{"Power", "[", 
          RowBox[{"zz", ",", "i"}], "]"}], "->", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Power", "[", 
              RowBox[{
               FractionBox[
                RowBox[{"1", "+", "u", "-", "v", "+", 
                 SqrtBox[
                  RowBox[{
                   RowBox[{
                    RowBox[{"-", "4"}], " ", "u"}], "+", 
                   SuperscriptBox[
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "-", "u", "+", "v"}], ")"}], 
                    "2"]}]]}], 
                RowBox[{"2", " ", "u"}]], ",", "i"}], "]"}], "/.", 
             RowBox[{"{", 
              RowBox[{"v", "->", 
               RowBox[{"1", "-", "Y"}]}], "}"}]}], "//", "Expand"}], "//", 
           RowBox[{
            RowBox[{"Collect", "[", 
             RowBox[{"#", ",", 
              RowBox[{"Power", "[", 
               RowBox[{"_", ",", 
                RowBox[{"1", "/", "2"}]}], "]"}], ",", "Factor"}], "]"}], 
            "&"}]}], ")"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "10"}], "}"}]}], "]"}], "//", 
    "Flatten"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.940113084556274*^9, 3.940113181187015*^9}, {
  3.940113548045265*^9, 3.940113549202723*^9}, {3.941011913633547*^9, 
  3.9410119244135933`*^9}},
 CellLabel->
  "In[659]:=",ExpressionUUID->"3fa1c4f6-4535-4579-9334-558c35306953"],

Cell["\<\
1/(1-v) under the transformation will become u/(u-v), but we will remove an \
overall u from expression, so the additional factor is 1/(u-v)\
\>", "Text",
 CellChangeTimes->{{3.986271110280031*^9, 
  3.986271157827806*^9}},ExpressionUUID->"f9237bef-3eb8-4a61-978e-\
c7d92c970ead"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"svlisteinfuv", "=", 
   RowBox[{"SeriesExpansionInf", "[", 
    RowBox[{"svlisteinf", ",", "zrep", ",", 
     RowBox[{"\"\<Yorder\>\"", "->", "4"}], ",", 
     RowBox[{"\"\<additional\>\"", "->", 
