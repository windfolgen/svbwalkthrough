             RowBox[{"ParallelTable", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"Series", "[", 
                  RowBox[{
                   RowBox[{"test", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"u", ",", "0", ",", "0"}], "}"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"Y", ",", "0", ",", 
                    RowBox[{"OptionValue", "[", "\"\<Yorder\>\"", "]"}]}], 
                    "}"}], ",", 
                   RowBox[{"Assumptions", "->", 
                    RowBox[{"{", 
                    RowBox[{"Y", ">", "0"}], "}"}]}]}], "]"}], "//", 
                 "Normal"}], "//", "Expand"}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "1", ",", 
                 RowBox[{"Length", "[", "test", "]"}]}], "}"}]}], "]"}]}], 
            ";", "\[IndentingNewLine]", 
            RowBox[{"Sow", "[", 
             RowBox[{
              RowBox[{"test1", "//", "Total"}], "//", "Expand"}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{"i", ",", "\"\< finished\>\""}], "]"}]}], 
           "\[IndentingNewLine]", ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"Length", "[", "temp", "]"}]}], "}"}]}], "]"}], "]"}], 
        "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
