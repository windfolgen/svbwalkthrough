Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "CutOneLoop", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "CutOneLoop", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{"deBug", "->", "True"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"CutOneLoop", "[", 
    RowBox[{
    "cutlist_", ",", "numlist_", ",", "var_", ",", "replambda_", ",", 
     "remain_", ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "select", ",", "subset", ",", "i", ",", "jacob", ",", "tem", ",", 
       "temvar", ",", "tem1", ",", "tem2", ",", "tem22", ",", "tem3", ",", 
       "temlist", ",", "den", ",", "num", ",", "sol", ",", "temsol", ",", 
       "sys", ",", "const", ",", "j", ",", "k", ",", "l", ",", "s", ",", 
       "tag", ",", 
       RowBox[{"replam", "=", 
        RowBox[{"{", "}"}]}], ",", "result", ",", "num1", ",", "den1", ",", 
       "temsys", ",", "temsys1", ",", "temsys2", ",", "sqrt", ",", "mark", 
       ",", "temmark", ",", "temnum", ",", 
       RowBox[{"checksol", "=", 
        RowBox[{"{", "}"}]}], ",", "checkps"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<    cut \>\"", ",", "cutlist", ",", "\"\< for \>\"", ",", 
        RowBox[{"Subscript", "[", 
         RowBox[{"x", ",", "var"}], "]"}], ",", "\"\<. numerator: \>\"", ",", 
        
        RowBox[{"Style", "[", 
         RowBox[{
          RowBox[{"Times", "@@", "numlist"}], ",", 
          RowBox[{"RGBColor", "[", 
           RowBox[{"0.4", ",", "0.53", ",", "1."}], "]"}]}], "]"}]}], "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"select", "=", 
       RowBox[{"Select", "[", 
        RowBox[{"cutlist", ",", 
         RowBox[{
          RowBox[{"Not", "@", 
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", "var"}], "]"}]}], "&"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"subset", "=", 
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{"Subsets", "[", 
          RowBox[{"select", ",", "4"}], "]"}], ",", 
         RowBox[{
          RowBox[{"AdmissibleCutQ", "[", 
           RowBox[{"#", ",", "var", ",", "replambda"}], "]"}], "&"}]}], 
        "]"}]}], ";", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "we", " ", "choose", " ", "proper", " ", "subset", " ", "that", " ", 
         "can", " ", "contribute", " ", "4", " ", "conditions"}], ",", " ", 
        RowBox[{
        "some", " ", "lower", " ", "sets", " ", "can", " ", "also", " ", 
         "contribute", " ", "4", " ", "conditions"}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<    totally \>\"", ",", 
        RowBox[{"Length", "[", "subset", "]"}], ",", "\"\< cases:\>\""}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"subset", "===", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{"\"\<select: \>\"", ",", "select"}], "]"}], ";", 
           RowBox[{"Print", "[", 
            RowBox[{"\"\<replambda: \>\"", ",", "replambda"}], "]"}]}]}], 
         "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"result", "=", 
       RowBox[{
        RowBox[{"Reap", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Do", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"Print", "[", 
              RowBox[{
               RowBox[{"Style", "[", 
                RowBox[{"\"\<        case \>\"", ",", "Orange", ",", "15"}], 
                "]"}], ",", "i", ",", "\"\<: \>\"", ",", 
               RowBox[{"subset", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"tem1", "=", 
              RowBox[{"DeleteCases", "[", 
               RowBox[{
                RowBox[{"subset", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], ",", 
                RowBox[{"_", "?", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"!", 
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"#", ",", "\[Lambda]"}], "]"}]}], "&"}], 
                  ")"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"tem2", "=", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"Cases", "[", 
                 RowBox[{
                  RowBox[{"subset", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], ",", 
                  RowBox[{"_", "?", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"!", 
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"#", ",", "\[Lambda]"}], "]"}]}], "&"}], 
                    ")"}]}]}], "]"}], ")"}], "/.", "replambda"}]}], ";", 
             RowBox[{"(*", 
              RowBox[{
              "terms", " ", "related", " ", "to", " ", "square", " ", 
               "roots"}], "*)"}], "\[IndentingNewLine]", 
             RowBox[{"tem3", "=", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"Cases", "[", 
                   RowBox[{
                    RowBox[{"{", "#", "}"}], ",", 
                    RowBox[{
                    RowBox[{"HoldPattern", "[", 
                    RowBox[{"V2", "[", 
                    RowBox[{"x", "[", 
                    RowBox[{"_", ",", "var"}], "]"}], "]"}], "]"}], "|", 
                    RowBox[{"HoldPattern", "[", 
                    RowBox[{"V2", "[", 
                    RowBox[{"x", "[", 
                    RowBox[{"var", ",", "_"}], "]"}], "]"}], "]"}]}], ",", 
                    "Infinity"}], "]"}], "//", "DeleteDuplicates"}], ")"}], 
                "&"}], "/@", 
               RowBox[{"Join", "[", 
                RowBox[{"tem1", ",", "tem2"}], "]"}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"temvar", "=", 
