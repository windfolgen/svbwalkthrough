                 RowBox[{"dis", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "}"}]}], "]"}]}], ")"}]}], "//", 
           RowBox[{
            RowBox[{"DeleteCases", "[", 
             RowBox[{"#", ",", 
              RowBox[{"_", "?", "NumericQ"}]}], "]"}], "&"}]}]}], ";", 
