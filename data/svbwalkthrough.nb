       RowBox[{"x", "[", 
        RowBox[{"3", ",", "5"}], "]"}], " ", 
       RowBox[{"x", "[", 
        RowBox[{"4", ",", "6"}], "]"}]}], "-", 
      RowBox[{
       RowBox[{"x", "[", 
        RowBox[{"3", ",", "4"}], "]"}], " ", 
       RowBox[{"x", "[", 
        RowBox[{"5", ",", "6"}], "]"}]}]}], ")"}]}], 
   RowBox[{
    RowBox[{"x", "[", 
     RowBox[{"1", ",", "5"}], "]"}], " ", 
