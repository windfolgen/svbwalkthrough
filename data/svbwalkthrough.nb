Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "AdmissibleCutQ", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "AdmissibleCutQ", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{"deBug", "->", "False"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AdmissibleCutQ", "[", 
    RowBox[{"cut_", ",", "var_", ",", "replambda_", ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "temint", ",", "temhint", ",", "vlist", ",", "powint", ",", "powhint", 
       ",", "rep", ",", "R"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"temint", "=", 
       RowBox[{"DeleteCases", "[", 
        RowBox[{"cut", ",", 
         RowBox[{"_", "?", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"FreeQ", "[", 
              RowBox[{"#", ",", "\[Lambda]"}], "]"}]}], "&"}], ")"}]}]}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"temhint", "=", 
       RowBox[{
        RowBox[{"Complement", "[", 
         RowBox[{"cut", ",", "temint"}], "]"}], "/.", "replambda"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"vlist", "=", 
       RowBox[{
        RowBox[{"Cases", "[", 
         RowBox[{
          RowBox[{"Join", "[", 
           RowBox[{"temint", ",", "temhint"}], "]"}], ",", 
          RowBox[{
           RowBox[{"HoldPattern", "[", 
            RowBox[{"V2", "[", 
             RowBox[{"x", "[", 
              RowBox[{"_", ",", "var"}], "]"}], "]"}], "]"}], "|", 
           RowBox[{"HoldPattern", "[", 
            RowBox[{"V2", "[", 
             RowBox[{"x", "[", 
              RowBox[{"var", ",", "_"}], "]"}], "]"}], "]"}]}], ",", 
          "Infinity"}], "]"}], "//", "DeleteDuplicates"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"OptionValue", "[", "deBug", "]"}], ",", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<temint: \>\"", ",", "temint"}], "]"}], ";", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<temhint: \>\"", ",", "temhint"}], "]"}], ";", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<vlist: \>\"", ",", "vlist"}], "]"}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "vlist", "]"}], "<", "4"}], ",", 
        RowBox[{"Return", "[", "False", "]"}]}], "]"}], ";", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "there", " ", "are", " ", "less", " ", "than", " ", "4", " ", 
         "variables"}], ",", " ", 
        RowBox[{
        "then", " ", "this", " ", "cannot", " ", "be", " ", "a", " ", 
         "complete", " ", "cut"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"rep", "=", 
       RowBox[{"Thread", "@", 
        RowBox[{"Rule", "[", 
         RowBox[{"vlist", ",", 
          RowBox[{"R", "*", "vlist"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"powint", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Exponent", "[", 
          RowBox[{"#", ",", "R"}], "]"}], "&"}], "/@", 
        RowBox[{"(", 
         RowBox[{"temint", "/.", "rep"}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"powhint", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Floor", "[", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Exponent", "[", 
             RowBox[{"#", ",", "R"}], "]"}], "/", "2"}], ")"}], "]"}], "&"}], 
        "/@", 
        RowBox[{"(", 
         RowBox[{"temhint", "/.", "rep"}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Total", "[", "powint", "]"}], "+", 
          RowBox[{"Total", "[", "powhint", "]"}]}], "<", "4"}], ",", 
        RowBox[{"Return", "[", "False", "]"}]}], "]"}], ";", 
      RowBox[{"(*", 
       RowBox[{
       "the", " ", "conditions", " ", "are", " ", "less", " ", "than", " ", 
        "4"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "True", "]"}], ";"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]}], "Input",
 InitializationCell->True,
