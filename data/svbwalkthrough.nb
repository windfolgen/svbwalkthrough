                    RowBox[{"Power", "[", 
                    RowBox[{"z", ",", 
                    RowBox[{"a_", "/;", 
                    RowBox[{"(", 
                    RowBox[{"a", "<", "0"}], ")"}]}]}], "]"}], ":>", 
                    RowBox[{"Power", "[", 
                    RowBox[{
                    RowBox[{"zz", "*", "u"}], ",", 
