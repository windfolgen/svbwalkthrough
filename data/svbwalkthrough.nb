 RowBox[{
  RowBox[{"ClearAll", "[", "SeriesExpansionInf", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "SeriesExpansionInf", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<additional\>\"", "->", "1"}], ",", 
     RowBox[{"\"\<Yorder\>\"", "->", "5"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SeriesExpansionInf", "[", 
    RowBox[{"temp_", ",", "zrep_", ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"result", ",", "test", ",", "test1"}], "}"}], ",", 
     "\[IndentingNewLine]", 
