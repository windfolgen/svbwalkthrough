Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "ResolveOrder", "]"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "resolve", " ", "the", " ", "solving", " ", "order", " ", "of", " ", 
    "loop", " ", "momenta"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "ResolveOrder", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{"\"\<order\>\"", "->", "0"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ResolveOrder", "[", 
    RowBox[{"den_", ",", "num_", ",", "loops_", ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "var", ",", "numlabel", ",", "denlabel", ",", "slist", ",", "order"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"numlabel", "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Cases", "[", 
           RowBox[{
            RowBox[{"{", "#", "}"}], ",", 
            RowBox[{
             RowBox[{"HoldPattern", "[", 
              RowBox[{"x", "[", 
               RowBox[{"a_", ",", "b_"}], "]"}], "]"}], "->", 
             RowBox[{"{", 
              RowBox[{"a", ",", "b"}], "}"}]}], ",", "Infinity"}], "]"}], 
          "&"}], "/@", "num"}], "//", 
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{"#", ",", "1"}], "]"}], "&"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"denlabel", "=", 
       RowBox[{"Cases", "[", 
        RowBox[{"den", ",", 
         RowBox[{
          RowBox[{"Subscript", "[", 
           RowBox[{"\[Lambda]", ",", "a_"}], "]"}], ":>", 
          RowBox[{"(", 
           RowBox[{"a", "//", "Flatten"}], ")"}]}], ",", "Infinity"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"\"\<numlabel: \>\"", ",", "numlabel"}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{"\"\<numlabel: \>\"", ",", "denlabel"}], "]"}], ";"}], 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{"slist", "=", 
       RowBox[{
        RowBox[{"Reap", "[", "\[IndentingNewLine]", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"AnyTrue", "[", 
              RowBox[{"denlabel", ",", 
               RowBox[{
                RowBox[{"ContainsAll", "[", 
                 RowBox[{"#", ",", 
                  RowBox[{"numlabel", "[", 
                   RowBox[{"[", "j", "]"}], "]"}]}], "]"}], "&"}]}], "]"}], 
             ",", 
             RowBox[{"Sow", "[", 
              RowBox[{"numlabel", "[", 
               RowBox[{"[", "j", "]"}], "]"}], "]"}]}], "]"}], 
           "\[IndentingNewLine]", ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "1", ",", 
             RowBox[{"Length", "[", "numlabel", "]"}]}], "}"}]}], "]"}], 
         "\[IndentingNewLine]", "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"slist", "===", 
         RowBox[{"{", "}"}]}], ",", 
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<       There may be no solvable order of variables:\>\"", ",", 
          "\"\<den: \>\"", ",", "den", ",", "\"\<num: \>\"", ",", "num"}], 
         "]"}], ",", 
        RowBox[{"slist", "=", 
         RowBox[{"slist", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"order", "=", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Count", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"FreeQ", "[", 
                 RowBox[{"#", ",", 
                  RowBox[{"loops", "[", 
                   RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "&"}], "/@", 
               "num"}], ",", "False"}], "]"}], ",", 
            RowBox[{"-", 
             RowBox[{"Count", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"FreeQ", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{"loops", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "&"}], "/@", 
                "slist"}], ",", "False"}], "]"}]}], ",", 
            RowBox[{"-", 
             RowBox[{"Count", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"FreeQ", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{"loops", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "&"}], "/@", 
                "denlabel"}], ",", "False"}], "]"}]}], ",", 
            RowBox[{"loops", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "[", "loops", "]"}]}], "}"}]}], "]"}], "//", 
        RowBox[{
         RowBox[{"SortBy", "[", 
          RowBox[{"#", ",", 
           RowBox[{"{", 
            RowBox[{"First", ",", 
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "&"}], ",", 
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "3", "]"}], "]"}], "&"}]}], "}"}]}], "]"}], 
         "&"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"OptionValue", "[", "\"\<order\>\"", "]"}], "==", "0"}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"order", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", 
            RowBox[{"-", "1"}]}], "]"}], "]"}], "]"}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{
          RowBox[{"order", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", 
             RowBox[{"-", "1"}]}], "]"}], "]"}], "//", "Reverse"}], "]"}]}], 
       "]"}], ";"}]}], "\[IndentingNewLine]", "]"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.945928228017461*^9, 3.945928277978856*^9}, {
   3.945928335861463*^9, 3.945928523313321*^9}, {3.945928561275607*^9, 
   3.9459285623841352`*^9}, {3.945928610425026*^9, 3.945928646542355*^9}, {
   3.945928694514257*^9, 3.945928867104174*^9}, {3.945928910393342*^9, 
   3.945928913584408*^9}, {3.945928997658208*^9, 3.945929092910676*^9}, {
   3.945929139448598*^9, 3.945929236775642*^9}, {3.94592938505923*^9, 
   3.945929388387328*^9}, {3.9459294243207903`*^9, 3.945929428165382*^9}, {
   3.945929484009206*^9, 3.945929501059643*^9}, {3.94592954694634*^9, 
   3.945929551138192*^9}, {3.945929581201523*^9, 3.945929582649308*^9}, 
   3.945929625659389*^9, {3.984821087609959*^9, 3.984821142997572*^9}},
 CellLabel->"In[43]:=",ExpressionUUID->"f80b4ccc-cb44-4a9e-a95e-ca7feab02a3d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "LeadingSingularities", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "LeadingSingularities", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"deBug", "->", "False"}], ",", 
     RowBox[{"\"\<outputlevel\>\"", "->", "2"}], ",", 
     RowBox[{"\"\<external\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}]}], ",", 
     RowBox[{"\"\<order\>\"", "->", "0"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"LeadingSingularities", "[", 
    RowBox[{"integrand_", ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "graph", ",", "agraph", ",", "sgraph", ",", "edgeden", ",", "edgenum", 
       ",", "loops", ",", "tem", ",", "pos", ",", "tem1", ",", "tem2", ",", 
       "remain", ",", 
       RowBox[{"k", "=", "1"}], ",", "l", ",", "cutlist", ",", "numlist", ",",
        "temcut", ",", "temnum", ",", "jacob", ",", 
       RowBox[{"replambda", "=", 
        RowBox[{"{", "}"}]}], ",", "subset", ",", "temrep", ",", "ls"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Head", "[", 
           RowBox[{"Denominator", "[", "integrand", "]"}], "]"}], "===", 
          "Plus"}], "||", 
         RowBox[{
          RowBox[{"Head", "[", 
           RowBox[{"Numerator", "[", "integrand", "]"}], "]"}], "===", 
          "Plus"}]}], ",", 
        RowBox[{
         RowBox[{
         "Print", "[", 
          "\"\<The denominator or numerator should be monomial!\>\"", "]"}], 
         ";", 
         RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"edgeden", "=", 
       RowBox[{"UndirectedEdge", "@@@", 
        RowBox[{"(", 
         RowBox[{"Cases", "[", 
          RowBox[{
           RowBox[{"Denominator", "[", "integrand", "]"}], ",", 
           RowBox[{"HoldPattern", "[", 
            RowBox[{"x", "[", 
             RowBox[{"_", ",", "_"}], "]"}], "]"}], ",", "Infinity"}], "]"}], 
         ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"edgenum", "=", 
       RowBox[{"UndirectedEdge", "@@@", 
        RowBox[{"(", 
         RowBox[{"Cases", "[", 
          RowBox[{
           RowBox[{"Numerator", "[", "integrand", "]"}], ",", 
           RowBox[{"HoldPattern", "[", 
            RowBox[{"x", "[", 
             RowBox[{"_", ",", "_"}], "]"}], "]"}], ",", "Infinity"}], "]"}], 
         ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"graph", "=", 
       RowBox[{"Graph", "[", 
        RowBox[{
         RowBox[{"Join", "[", 
          RowBox[{"edgeden", ",", "edgenum"}], "]"}], ",", 
         RowBox[{"VertexLabels", "->", "\"\<Name\>\""}], ",", 
         RowBox[{"VertexStyle", "->", 
          RowBox[{"Thread", "@", 
           RowBox[{"Rule", "[", 
            RowBox[{
             RowBox[{"OptionValue", "[", "\"\<external\>\"", "]"}], ",", 
             "Red"}], "]"}]}]}], ",", 
         RowBox[{"EdgeStyle", "->", 
          RowBox[{"Thread", "@", 
           RowBox[{"Rule", "[", 
            RowBox[{"edgenum", ",", "Dashed"}], "]"}]}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"\"\<the graph: \>\"", ",", "graph"}], "]"}], ";"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<denom graph: \>\"", ",", 
        RowBox[{"Graph", "[", 
         RowBox[{"edgeden", ",", 
          RowBox[{"VertexLabels", "->", "\"\<Name\>\""}], ",", 
          RowBox[{"VertexStyle", "->", 
           RowBox[{"Thread", "@", 
            RowBox[{"Rule", "[", 
             RowBox[{
              RowBox[{"OptionValue", "[", "\"\<external\>\"", "]"}], ",", 
              "Red"}], "]"}]}]}]}], "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"loops", "=", 
       RowBox[{"Complement", "[", 
        RowBox[{
         RowBox[{"VertexList", "[", "graph", "]"}], ",", 
         RowBox[{"OptionValue", "[", "\"\<external\>\"", "]"}]}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<the loop variables are \>\"", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"Subscript", "[", 
           RowBox[{"x", ",", "#"}], "]"}], "&"}], "/@", "loops"}]}], "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"cutlist", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"V2", "/@", "edgeden"}], ")"}], "/.", 
        RowBox[{"{", 
         RowBox[{"UndirectedEdge", "->", "x"}], "}"}]}]}], ";", 
      RowBox[{"(*", 
       RowBox[{
       "the", " ", "candidated", " ", "to", " ", "be", " ", "cut", " ", "is", 
        " ", "set", " ", "to", " ", "denominators", " ", "at", " ", "first"}],
        "*)"}], "\[IndentingNewLine]", 
      RowBox[{"numlist", "=", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Head", "[", 
            RowBox[{"Numerator", "[", "integrand", "]"}], "]"}], "===", 
           "Times"}], ",", 
          RowBox[{"List", "@@", 
