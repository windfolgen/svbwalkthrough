          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{"list", "=", "olist"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<the ordering of external legs is \>\"", ",", "list", ",", " ", 
        "\"\< the expression of svmpl is related to this ordering!\>\""}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"num", "=", 
