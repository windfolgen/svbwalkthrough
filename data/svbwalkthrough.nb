Cell[TextData[StyleBox["Through this leading singularity analysis, we know if \
we change the numerator from x[3,4]x[5,6] to \
x[3,4]x[5,6]-x[3,6]x[4,5]-x[3,5]x[4,6], then the leading singularity of \
1/(z-zz)^2 is separated. Then this integrand can be split into two parts:",
 FontColor->RGBColor[1, 0.5, 0]]], "Text",
 CellDingbat->"\[Wolf]",
 CellChangeTimes->{{3.986193019667716*^9, 
  3.986193147849442*^9}},ExpressionUUID->"5ff99a46-2434-473a-9a9c-\
1536d1c9b622"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"inthard1", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"x", "[", 
          RowBox[{"5", ",", "6"}], "]"}], "*", 
         RowBox[{"x", "[", 
          RowBox[{"3", ",", "4"}], "]"}]}], "-", 
        RowBox[{
