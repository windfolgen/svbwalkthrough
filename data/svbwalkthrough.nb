         RowBox[{
          RowBox[{"Head", "[", 
           RowBox[{"nsl", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "]"}], "===", "Times"}], ",", 
         RowBox[{"List", "@@", 
          RowBox[{"nsl", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"nsl", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{"rl", ",", 
         RowBox[{"nsl", "//", 
          RowBox[{
