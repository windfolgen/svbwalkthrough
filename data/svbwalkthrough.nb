842478ed3ef6"],

Cell["To construct a canonical DCI integrand for a given word", "Text",
 CellChangeTimes->{{3.958683197781361*^9, 
  3.958683214236937*^9}},ExpressionUUID->"bb049f02-58e1-46df-a244-\
bd288ac319f6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "CanonicalDCI", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"CanonicalDCI", "[", "word_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"list", ",", "initial", ",", "int", ",", "count"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"StringQ", "[", "word", "]"}], ",", 
        RowBox[{"list", "=", 
         RowBox[{"ToExpression", "/@", 
          RowBox[{"(", 
           RowBox[{"StringPartition", "[", 
            RowBox[{"word", ",", "1"}], "]"}], ")"}]}]}], ",", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Head", "[", "word", "]"}], "===", "List"}], ",", 
          RowBox[{"list", "=", "word"}]}], "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"int", "=", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "[", 
           RowBox[{"1", ",", "5"}], "]"}], 
          RowBox[{"x", "[", 
           RowBox[{"2", ",", "5"}], "]"}], 
          RowBox[{"x", "[", 
           RowBox[{"3", ",", "5"}], "]"}], 
          RowBox[{"x", "[", 
           RowBox[{"4", ",", "5"}], "]"}]}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"count", "=", "6"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Do", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"list", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "===", "0"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"int", "=", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"int", "/.", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"x", "[", "a__", "]"}], ":>", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"x", "[", "a", "]"}], "/.", 
                   RowBox[{"{", 
                    RowBox[{"1", "->", "count"}], "}"}]}], ")"}]}], "}"}]}], 
              ")"}], "*", 
             RowBox[{
              RowBox[{
               RowBox[{"x", "[", 
                RowBox[{"2", ",", "4"}], "]"}], "/", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"x", "[", 
                  RowBox[{"count", ",", "2"}], "]"}], 
                 RowBox[{"x", "[", 
                  RowBox[{"count", ",", "4"}], "]"}]}], ")"}]}], "/", 
              RowBox[{"x", "[", 
               RowBox[{"1", ",", "count"}], "]"}]}]}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"int", "=", 
             RowBox[{"int", "*", 
              RowBox[{
               RowBox[{"x", "[", 
                RowBox[{"1", ",", "2"}], "]"}], "/", 
               RowBox[{"(", 
