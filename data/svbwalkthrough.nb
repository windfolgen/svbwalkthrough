    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{"dirasym", ",", "\"\<checkI3Lhardt1234_order3_asyexp.m\>\""}], 
      "}"}], "]"}], "]"}], "//", "Normal", 
   RowBox[{"(*", 
    RowBox[{"{", 
     RowBox[{"u", ",", "v"}], "}"}], "*)"}]}]}]], "Input",
