Cell[CellGroupData[{

Cell["Section 5: Calculate the expansion of ansatz", "Section",
 CellChangeTimes->{{3.986254446426149*^9, 
  3.986254483699592*^9}},ExpressionUUID->"0b8bd8cb-0245-4b29-9fe0-\
fbab3ae3aefa"],

Cell[TextData[{
 StyleBox["Now since we know the leading singularity is ",
  FontSize->18],
 StyleBox["1/(z-zz)/(1-v)",
  FontSize->18,
  FontColor->RGBColor[1, 0, 0]],
 StyleBox[", then we need to expand our ansatz to the same O(u^0,Y^3) to \
match the boundary condition we calculated in the last section ",
  FontSize->18]
}], "Text",
 CellChangeTimes->{{3.986254490739622*^9, 
  3.9862545837031612`*^9}},ExpressionUUID->"7d2b0b18-4428-44ee-9586-\
4b4044a0c18d"],

Cell[TextData[StyleBox["First, we need to expand all single-valued integrals \
involved in our ansatz with respect to z,zz up to some order in maple. Then \
we transform the expansion with respect to z,zz to expansion with respect to \
u and v in this Mathematica notebook.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.9862562583979*^9, 
  3.986256358189191*^9}},ExpressionUUID->"de546440-6c95-4571-9482-\
4b83fc054d64"],

Cell[TextData[StyleBox["Same as before, we have calculated the expansion of \
all svmpls up to weight 8 in Maple (You can also calculate them using your \
agents). Here we just load them. So the first step is already done.",
 FontSize->18]], "Text",
 CellChangeTimes->{{3.9862563692842703`*^9, 3.9862563699267817`*^9}, {
   3.986256416271974*^9, 3.9862564780675917`*^9}, {3.98625654361626*^9, 
   3.986256655149239*^9}, 
   3.9862567463171263`*^9},ExpressionUUID->"a3851177-2ad5-4f08-b62f-\
6f57f7b1db12"],

Cell[BoxData[
 RowBox[{
  RowBox[{"allsvlist", "=", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"I", "[", 
          RowBox[{"z", ",", 
           RowBox[{"Sequence", "@@", "#"}], ",", "0"}], "]"}], "&"}], "/@", 
        RowBox[{"Tuples", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "1"}], "}"}], ",", "i"}], "]"}]}], ")"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "8"}], "}"}]}], "]"}], "//", "Flatten"}]}],
   ";"}]], "Input",
 CellLabel->
  "In[645]:=",ExpressionUUID->"e1852f52-d6a5-4814-bf82-09c5acdbcead"],

