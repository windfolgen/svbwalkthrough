Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "PartialRowReduce", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PartialRowReduce", "[", 
    RowBox[{"mat1_", ",", "mat2_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tem", ",", "temmat", ",", "temmat1", ",", "rank"}], "}"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"tem", "=", 
       RowBox[{"mat1", "//", 
        RowBox[{
         RowBox[{"SortBy", "[", 
          RowBox[{"#", ",", "LeafCount"}], "]"}], "&"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"temmat", "=", "mat2"}], ";", "\[IndentingNewLine]", 
      RowBox[{"rank", "=", 
       RowBox[{"MatrixRank", "[", "temmat", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Do", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"temmat1", "=", 
          RowBox[{"Append", "[", 
           RowBox[{"temmat", ",", 
            RowBox[{"tem", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"MatrixRank", "[", "temmat1", "]"}], "-", "rank"}], "==",
             "1"}], ",", 
           RowBox[{
            RowBox[{"temmat", "=", "temmat1"}], ";", 
            RowBox[{"rank", "=", 
             RowBox[{"rank", "+", "1"}]}], ";"}]}], "]"}]}], 
        "\[IndentingNewLine]", ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          RowBox[{"Length", "[", "tem", "]"}]}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "temmat", "]"}], ";"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.987498245239901*^9, 3.987498428579165*^9}, {
  3.9874984711744623`*^9, 3.987498501212005*^9}, {3.987498545537636*^9, 
