                    "2"]}]]}], 
                    RowBox[{"2", " ", "u"}]]}]}], "}"}]}], "/.", 
                RowBox[{"{", 
                 RowBox[{"v", "->", 
                  RowBox[{"1", "-", "Y"}]}], "}"}]}], "//", "Expand"}], 
              ")"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
