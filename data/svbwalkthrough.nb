  RowBox[{"4", " ", 
   SuperscriptBox[
    RowBox[{"Log", "[", "u", "]"}], "2"]}], "-", 
  FractionBox[
   SuperscriptBox[
    RowBox[{"Log", "[", "u", "]"}], "3"], "3"], "+", 
  RowBox[{"Y", " ", 
   RowBox[{"(", 
    RowBox[{
     FractionBox["265", "8"], "-", 
     FractionBox[
      RowBox[{"137", " ", 
       RowBox[{"Log", "[", "u", "]"}]}], "8"], "+", 
     FractionBox[
      RowBox[{"15", " ", 
       SuperscriptBox[
        RowBox[{"Log", "[", "u", "]"}], "2"]}], "4"], "-", 
     FractionBox[
      RowBox[{"3", " ", 
       SuperscriptBox[
        RowBox[{"Log", "[", "u", "]"}], "3"]}], "8"], "-", 
     RowBox[{"18", " ", 
      RowBox[{"Zeta", "[", "3", "]"}]}]}], ")"}]}], "+", 
  RowBox[{
   SuperscriptBox["Y", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     FractionBox["82735", "2916"], "-", 
     FractionBox[
      RowBox[{"14273", " ", 
       RowBox[{"Log", "[", "u", "]"}]}], "972"], "+", 
     FractionBox[
      RowBox[{"539", " ", 
       SuperscriptBox[
        RowBox[{"Log", "[", "u", "]"}], "2"]}], "162"], "-", 
     FractionBox[
      RowBox[{"121", " ", 
       SuperscriptBox[
        RowBox[{"Log", "[", "u", "]"}], "3"]}], "324"], "-", 
     FractionBox[
      RowBox[{"484", " ", 
       RowBox[{"Zeta", "[", "3", "]"}]}], "27"]}], ")"}]}], "+", 
  RowBox[{
   SuperscriptBox["Y", "3"], " ", 
   RowBox[{"(", 
    RowBox[{
     FractionBox["3122795", "124416"], "-", 
     FractionBox[
      RowBox[{"268025", " ", 
       RowBox[{"Log", "[", "u", "]"}]}], "20736"], "+", 
     FractionBox[
      RowBox[{"5125", " ", 
       SuperscriptBox[
        RowBox[{"Log", "[", "u", "]"}], "2"]}], "1728"], "-", 
     FractionBox[
      RowBox[{"625", " ", 
       SuperscriptBox[
        RowBox[{"Log", "[", "u", "]"}], "3"]}], "1728"], "-", 
     FractionBox[
      RowBox[{"625", " ", 
       RowBox[{"Zeta", "[", "3", "]"}]}], "36"]}], ")"}]}], "-", 
  RowBox[{"16", " ", 
   RowBox[{"Zeta", "[", "3", "]"}]}]}]], "Output",
