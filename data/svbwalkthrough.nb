Cell[BoxData[
 RowBox[{
  RowBox[{"zrep", "=", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Power", "[", 
          RowBox[{"z", ",", "i"}], "]"}], "->", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Power", "[", 
              RowBox[{
               FractionBox[
                RowBox[{
                 RowBox[{"-", "1"}], "+", "u", "+", "v", "-", 
                 SqrtBox[
                  RowBox[{
                   RowBox[{
                    RowBox[{"-", "4"}], " ", "u", " ", "v"}], "+", 
                   SuperscriptBox[
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", "u", "+", "v"}], ")"}], 
                    "2"]}]]}], 
                RowBox[{"2", " ", "u"}]], ",", "i"}], "]"}], "/.", 
             RowBox[{"{", 
              RowBox[{"v", "->", 
               RowBox[{"1", "-", "Y"}]}], "}"}]}], "//", "Expand"}], "//", 
           RowBox[{
            RowBox[{"Collect", "[", 
             RowBox[{"#", ",", 
              RowBox[{"Power", "[", 
               RowBox[{"_", ",", 
                RowBox[{"1", "/", "2"}]}], "]"}], ",", "Factor"}], "]"}], 
            "&"}]}], ")"}]}], ",", 
        RowBox[{
         RowBox[{"Power", "[", 
          RowBox[{"zz", ",", "i"}], "]"}], "->", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Power", "[", 
              RowBox[{
               FractionBox[
                RowBox[{
                 RowBox[{"-", "1"}], "+", "u", "+", "v", "+", 
                 SqrtBox[
                  RowBox[{
                   RowBox[{
                    RowBox[{"-", "4"}], " ", "u", " ", "v"}], "+", 
                   SuperscriptBox[
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", "u", "+", "v"}], ")"}], 
                    "2"]}]]}], 
                RowBox[{"2", " ", "u"}]], ",", "i"}], "]"}], "/.", 
             RowBox[{"{", 
              RowBox[{"v", "->", 
               RowBox[{"1", "-", "Y"}]}], "}"}]}], "//", "Expand"}], "//", 
           RowBox[{
            RowBox[{"Collect", "[", 
             RowBox[{"#", ",", 
              RowBox[{"Power", "[", 
               RowBox[{"_", ",", 
                RowBox[{"1", "/", "2"}]}], "]"}], ",", "Factor"}], "]"}], 
            "&"}]}], ")"}]}]}], "}"}], ",", 
