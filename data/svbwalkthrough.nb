                    RowBox[{"OptionValue", "[", "\"\<additional\>\"", "]"}]}],
                     "/.", 
                    RowBox[{"{", 
                    RowBox[{"zz", "->", 
                    RowBox[{
                    RowBox[{"1", "/", "u"}], "/", "z"}]}], "}"}]}], "//", 
