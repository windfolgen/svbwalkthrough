Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "GraphReduce", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "GraphReduce", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{"\"\<external\>\"", "->", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"GraphReduce", "[", 
    RowBox[{"int_", ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"num", ",", "graph", ",", "list", ",", "result", ",", "temp"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"num", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Numerator", "[", "int", "]"}], "//", 
         RowBox[{
          RowBox[{"Cases", "[", 
           RowBox[{"#", ",", 
            RowBox[{"x", "[", "__", "]"}], ",", "Infinity"}], "]"}], "&"}]}], 
        "//", "DeleteDuplicates"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"graph", "=", 
       RowBox[{"drawGraph", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"int", ",", 
           RowBox[{"OptionValue", "[", "\"\<external\>\"", "]"}]}], "}"}], 
         ",", 
         RowBox[{"\"\<withoutnum\>\"", "->", "False"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"list", "=", 
       RowBox[{"FindSubgraphIsomorphism", "[", 
        RowBox[{
         RowBox[{"Graph", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"1", "\[UndirectedEdge]", "2"}], ",", 
            RowBox[{"2", "\[UndirectedEdge]", "3"}], ",", 
            RowBox[{"2", "\[UndirectedEdge]", "4"}], ",", 
            RowBox[{"2", "\[UndirectedEdge]", "5"}], ",", 
            RowBox[{"4", "\[UndirectedEdge]", "5"}]}], "}"}], "]"}], ",", 
         "graph", ",", "All"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"result", "=", 
       RowBox[{
        RowBox[{"Reap", "[", "\[IndentingNewLine]", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"Not", "@", 
               RowBox[{"MemberQ", "[", 
                RowBox[{"num", ",", 
                 RowBox[{"x", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"list", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", "4", "]"}], ",", 
                   RowBox[{
                    RowBox[{"list", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", "5", "]"}]}], 
                  "]"}]}], "]"}]}], ",", 
              RowBox[{"Continue", "[", "]"}]}], "]"}], ";", 
            RowBox[{"(*", 
             RowBox[{
              RowBox[{
              "if", " ", "this", " ", "is", " ", "not", " ", "a", " ", 
               "numerator"}], ",", " ", 
              RowBox[{"then", " ", "pass"}]}], "*)"}], "\[IndentingNewLine]", 
            
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"VertexDegree", "[", 
                 RowBox[{"graph", ",", 
                  RowBox[{
                   RowBox[{"list", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", "2", "]"}]}], "]"}], 
                "=!=", "4"}], "||", 
               RowBox[{"MemberQ", "[", 
                RowBox[{
                 RowBox[{"OptionValue", "[", "\"\<external\>\"", "]"}], ",", 
                 RowBox[{
                  RowBox[{"list", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "[", "3", "]"}]}], "]"}]}],
               ",", 
              RowBox[{"Continue", "[", "]"}]}], "]"}], ";", 
            RowBox[{"(*", 
             RowBox[{
             "the", " ", "degree", " ", "of", " ", "central", " ", "vertex", 
              " ", "must", " ", "be", " ", "4"}], "*)"}], 
            RowBox[{"(*", 
             RowBox[{
             "the", " ", "vertex", " ", "3", " ", "must", " ", "be", " ", 
              "internal"}], "*)"}], "\[IndentingNewLine]", 
            RowBox[{"Sow", "[", 
             RowBox[{"list", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
           ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"Length", "[", "list", "]"}]}], "}"}]}], "]"}], 
         "\[IndentingNewLine]", "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"result", "===", 
         RowBox[{"{", "}"}]}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"{", "}"}], "]"}], ",", 
        RowBox[{"result", "=", 
         RowBox[{"result", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"list", "=", 
       RowBox[{"result", "//", 
        RowBox[{
         RowBox[{"DeleteDuplicatesBy", "[", 
          RowBox[{"#", ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"#", "/@", 
              RowBox[{"{", 
               RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], ")"}], "&"}]}], 
          "]"}], "&"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{
        RowBox[{"Length", "[", "list", "]"}], ",", 
        "\"\< case(s) found after modding the symmetry\>\""}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", "\"\<Reducing the graph ... \>\"", "]"}], ";"}],
        "*)"}], "\[IndentingNewLine]", 
      RowBox[{"result", "=", 
       RowBox[{
        RowBox[{"Reap", "[", "\[IndentingNewLine]", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"temp", "=", 
             RowBox[{"list", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"Sow", "[", 
             RowBox[{
              RowBox[{"int", "*", 
               RowBox[{"x", "[", 
                RowBox[{
                 RowBox[{"temp", "[", "1", "]"}], ",", 
                 RowBox[{"temp", "[", "2", "]"}]}], "]"}], "*", 
               RowBox[{"x", "[", 
                RowBox[{
                 RowBox[{"temp", "[", "2", "]"}], ",", 
                 RowBox[{"temp", "[", "3", "]"}]}], "]"}], "*", 
               RowBox[{"x", "[", 
                RowBox[{
                 RowBox[{"temp", "[", "2", "]"}], ",", 
                 RowBox[{"temp", "[", "4", "]"}]}], "]"}], "*", 
               RowBox[{
                RowBox[{
                 RowBox[{"x", "[", 
                  RowBox[{
                   RowBox[{"temp", "[", "2", "]"}], ",", 
                   RowBox[{"temp", "[", "5", "]"}]}], "]"}], "/", 
                 RowBox[{"x", "[", 
                  RowBox[{
                   RowBox[{"temp", "[", "4", "]"}], ",", 
                   RowBox[{"temp", "[", "5", "]"}]}], "]"}]}], "/", 
                RowBox[{"x", "[", 
                 RowBox[{
                  RowBox[{"temp", "[", "1", "]"}], ",", 
                  RowBox[{"temp", "[", "3", "]"}]}], "]"}]}]}], "//", 
              "Factor"}], "]"}]}], "\[IndentingNewLine]", ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"Length", "[", "list", "]"}]}], "}"}]}], "]"}], 
         "\[IndentingNewLine]", "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"Return", "[", "result", "]"}], ";"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]}], "Input",
 InitializationCell->True,
