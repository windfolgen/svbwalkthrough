             RowBox[{"(*", 
              RowBox[{
              "the", " ", "variables", " ", "involving", " ", "loop", " ", 
               "momenta"}], "*)"}], "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Length", "[", "temvar", "]"}], "<", "4"}], ",", 
               RowBox[{
                RowBox[{"Print", "[", 
                 RowBox[{
                 "\"\<        variable not enough. temvar: \>\"", ",", 
                  "temvar"}], "]"}], ";", 
                RowBox[{"Continue", "[", "]"}]}]}], "]"}], ";", 
             RowBox[{"(*", 
              RowBox[{
               RowBox[{"variables", " ", "less", " ", "than", " ", "4"}], ",",
                " ", 
               RowBox[{"not", " ", "solvable"}]}], "*)"}], 
             "\[IndentingNewLine]", "\[IndentingNewLine]", 
             RowBox[{"sys", "=", "tem1"}], ";", 
             RowBox[{"(*", 
              RowBox[{"initial", " ", "cut", " ", 
               RowBox[{"system", ".", " ", "cut"}], " ", "terms", " ", 
               "which", " ", "are", " ", "not", " ", "square", " ", "roots"}],
               "*)"}], "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"OptionValue", "[", "deBug", "]"}], ",", 
               RowBox[{
                RowBox[{"Print", "[", 
                 RowBox[{"\"\<temvar: \>\"", ",", "temvar"}], "]"}], ";", 
                RowBox[{"Print", "[", 
                 RowBox[{"\"\<initial sys: \>\"", ",", "sys"}], "]"}]}]}], 
              "]"}], ";", "\[IndentingNewLine]", 
             RowBox[{"sol", "=", 
              RowBox[{
               RowBox[{
                RowBox[{"Solve", "[", 
                 RowBox[{
                  RowBox[{"Thread", "@", 
                   RowBox[{"Equal", "[", 
                    RowBox[{"sys", ",", "0"}], "]"}]}], ",", "temvar"}], 
                 "]"}], "[", 
                RowBox[{"[", "1", "]"}], "]"}], "//", "Quiet"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"k", "=", "1"}], ";", "\[IndentingNewLine]", 
             RowBox[{"const", "=", 
              RowBox[{"{", "}"}]}], ";", 
             RowBox[{"(*", 
              RowBox[{
              "keep", " ", "track", " ", "of", " ", "constant", " ", 
               "terms"}], "*)"}], "\[IndentingNewLine]", 
             RowBox[{"checksol", "=", 
              RowBox[{"{", "}"}]}], ";", 
             RowBox[{"(*", 
              RowBox[{
              "this", " ", "solution", " ", "can", " ", "be", " ", "used", 
               " ", "to", " ", "check", " ", "some", " ", "cancellation", " ",
                "between", " ", "numerator", " ", "and", " ", "denominator"}],
               "*)"}], "\[IndentingNewLine]", 
             RowBox[{"While", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"Length", "[", "sol", "]"}], "<", "4"}], "&&", 
                RowBox[{"k", "<", "5"}]}], ",", 
               RowBox[{"(*", 
                RowBox[{
                 RowBox[{
                 "when", " ", "the", " ", "solution", " ", "is", " ", "not", 
                  " ", "enough"}], ",", " ", 
                 RowBox[{
                 "we", " ", "substitute", " ", "the", " ", "initial", " ", 
                  "solution", " ", "into", " ", "remaining", " ", "square", 
                  " ", "roots"}]}], "*)"}], "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{
                    RowBox[{"Length", "[", 
                    RowBox[{"subset", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "]"}], ">=", "4"}], "&&", 
                   
                   RowBox[{"tem2", "===", 
                    RowBox[{"{", "}"}]}]}], ",", "\[IndentingNewLine]", 
                  RowBox[{"Print", "[", 
                   RowBox[{
                    RowBox[{"Style", "[", 
                    RowBox[{
                    "\"\<        the conditions may be not enough for \>\"", 
                    ",", "Magenta"}], "]"}], ",", 
                    RowBox[{"Subscript", "[", 
                    RowBox[{"x", ",", "var"}], "]"}], ",", 
                    "\"\<. cut list: \>\"", ",", "cutlist", ",", 
                    "\"\< sublist: \>\"", ",", 
                    RowBox[{"subset", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], 
                 "\[IndentingNewLine]", "]"}], ";", 
                RowBox[{"(*", 
                 RowBox[{
                 "this", " ", "is", " ", "for", " ", "the", " ", "case", " ", 
                  "where", " ", "expression", " ", "under", " ", "square", 
                  " ", "roots", " ", "are", " ", "also", " ", "used", " ", 
                  "but", " ", "the", " ", "condition", " ", "is", " ", 
                  "still", " ", "not", " ", "enough"}], "*)"}], 
                "\[IndentingNewLine]", "\[IndentingNewLine]", 
                RowBox[{"tem22", "=", 
                 RowBox[{"PerfectSquareOut", "/@", 
                  RowBox[{"(", 
                   RowBox[{"tem2", "/.", "sol"}], ")"}]}]}], ";", 
                RowBox[{"(*", 
                 RowBox[{
                 "take", " ", "care", " ", "of", " ", "cases", " ", "where", 
                  " ", "the", " ", "square", " ", "root", " ", "is", " ", "0",
                   " ", "under", " ", "current", " ", "solution"}], "*)"}], 
                "\[IndentingNewLine]", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"MemberQ", "[", 
