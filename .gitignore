# macOS
.DS_Store
**/.DS_Store

# IDE local config (TRAE/Aether/etc.)
.trae/

# Aether IDE local ignore file
.aetherignore

# Machine-local override files (cloud paths, etc.)
local_overrides/

# Mathematica cache
*.mx
*.mx.bak

# Wolfram package index
*.wl.i

# Editor temp files
*~
*.swp

# Large intermediate data
IBPReduction*/
scratch/
test/

# Large data archives
*.tar.gz
*.zip

# Agent cache files and intermediate folders
asym/tmp/*
!asym/tmp/targetIntegrals_reduced.m
# asym/Bases/
asym/logs/
asym/boundary_agent/*
!asym/boundary_agent/*.wl
series_agent/*
!series_agent/*.wl
solve_agent/*
!solve_agent/*.wl

# Exclude large generated/run folders
extra/
log/
logs/
runs/fourloopI6boxing/
runs/fourloopI98/
runs/fourloopI108/
runs/fourloopI182/
runs/fourloopI218/
runs/fourloopI219/

# Exclude generated up-to-weight-8 SV .m basis files
data/*_uptow8_inuv*.m

# Generated result file
resulthard3L.m

# Reference/archive directory
reference/

# LaTeX build artifacts (leadingsingularity reports)
leadingsingularity/*.aux
leadingsingularity/*.bbl
leadingsingularity/*.blg
leadingsingularity/*.log
leadingsingularity/*.out
leadingsingularity/*.toc
